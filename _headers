/*
  Content-Security-Policy: default-src 'self'; base-uri 'none'; connect-src 'none'; font-src 'self'; form-action 'none'; frame-ancestors 'none'; frame-src 'none'; img-src 'self' data:; manifest-src 'self'; media-src 'none'; object-src 'none'; script-src 'self' 'sha256-AB3vLHP5wyW2WnXlAj54rcViSZbGFGjSb4CNJQnVB0s='; style-src 'self'; upgrade-insecure-requests
